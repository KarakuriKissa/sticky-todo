{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StickyTodo",
  "version": "0.1.0",
  "identifier": "com.stickytodo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "launcher",
        "title": "Sticky ToDo β",
        "width": 960,
        "height": 720,
        "minWidth": 600,
        "minHeight": 480,
        "url": "/",
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://api.github.com; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  }
}
