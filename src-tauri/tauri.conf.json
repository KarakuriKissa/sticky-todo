{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StickyTodo",
  "version": "0.1.0",
  "identifier": "com.stickytodo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "launcher",
        "title": "Sticky ToDo",
        "width": 960,
        "height": 640,
        "minWidth": 600,
        "minHeight": 400,
        "url": "/",
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  }
}
